# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# New Supabase projects may call this the publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Older projects may call the same public key the anon key. The app accepts either name.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini API
# Optional for demo mode. Without this key, AI endpoints return safe mock responses.
GEMINI_API_KEY=your_gemini_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Jam'iyya AI
CRON_SECRET=your_local_cron_secret_for_payment_cycle_jobs
